# 复制本文件为 .env 后按需修改

# ===== 服务 =====
NODE_ENV=development
PORT=3000

# ===== MySQL =====
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=123456
MYSQL_DATABASE=miniapp
MYSQL_CONNECTION_LIMIT=10

# ===== Redis =====
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ===== 微信小程序 =====
WX_APPID=your_wx_appid
WX_SECRET=your_wx_secret

# ===== JWT =====
JWT_SECRET=please_change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d

# ===== SMTP(留空则验证码打印到控制台,本地可直接跑) =====
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@example.com

# ===== 验证码 =====
VERIFY_CODE_TTL=300
VERIFY_COOLDOWN=60

# ===== 首次启动自动建管理员(两者都填且邮箱不存在时创建)=====
ADMIN_EMAIL=
ADMIN_PASSWORD=
