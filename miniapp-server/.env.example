# 复制本文件为 .env 后按需修改

# ===== 服务 =====
NODE_ENV=development
PORT=3000

# ===== MySQL =====
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=123456
MYSQL_DATABASE=miniapp
MYSQL_CONNECTION_LIMIT=10

# ===== Redis =====
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ===== 微信小程序 =====
WX_APPID=your_wx_appid
WX_SECRET=your_wx_secret

# ===== JWT =====
JWT_SECRET=please_change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d
