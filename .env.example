# =============================================================================
# 部署环境变量总模板(单镜像部署用)
# 用法:cp .env.example .env  然后按需修改;.env 已 gitignore,不会提交。
# docker compose 自动读取同目录 .env 来替换 docker-compose.yml 里的 ${...}。
# 不建 .env 也能跑——compose 里都有缺省值(密码 123456 / SMTP 留空走 mock)。
# 入口:http://localhost:3000 (前端页面 + /api 同一端口)
# =============================================================================

# ===== 数据库 / JWT(密钥,生产务必改)=====
MYSQL_PASSWORD=123456
JWT_SECRET=change_me_to_a_long_random_string

# ===== 首次启动自动建管理员(两者都填且邮箱不存在时自动创建 admin)=====
# 留空则不自动建,需自己注册后手动 UPDATE users SET role='admin'。
ADMIN_EMAIL=
ADMIN_PASSWORD=

# ===== SMTP(留空 SMTP_HOST => 验证码打到容器日志:./deploy.sh logs)=====
# 真发邮件示例(QQ 邮箱):
#   SMTP_HOST=smtp.qq.com
#   SMTP_PORT=465
#   SMTP_USER=你的QQ@qq.com
#   SMTP_PASS=16位授权码          # 秘密!不要提交
#   SMTP_FROM=你的QQ@qq.com
# 注意:部署机网络必须能出站连 SMTP(465),否则发信超时。
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@example.com
